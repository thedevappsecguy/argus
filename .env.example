# Copy this to .env and fill in your values (never commit .env to git)
# .env is gitignored — see .gitignore

# Gemini API key (required for the ADK agent pipeline)
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional model overrides (defaults shown)
# ARGUS_PRO_MODEL=gemini-2.5-pro
# ARGUS_FLASH_MODEL=gemini-2.5-flash
# ARGUS_TEMPERATURE=0.1
